    private void addInsert(StringBuilder cols, StringBuilder values, List<Object> params, String column, Object value)
    {
        if (value != null)
        {
            if (cols.length() > 0)
            {
                cols.append(", ");
                values.append(", ");
            }
            cols.append(column);
            values.append('?');
            params.add(value);
        }
    }

    private void addUpdate(StringBuilder sql, List<Object> params, String column, Object value)
    {
        if (value != null)
        {
            sql.append(column).append(" = ?, ");
            params.add(value);
        }
    }

    private void addWhere(StringBuilder sql, List<Object> params, String condition, Object value)
    {
        if (value instanceof String && StringUtils.isBlank((String) value))
        {
            return;
        }
        if (value != null)
        {
            sql.append(" and ").append(condition);
            params.add(value);
        }
    }

    private void addLikeWhere(StringBuilder sql, List<Object> params, String column, Object value)
    {
        if (value != null && StringUtils.isNotBlank(String.valueOf(value)))
        {
            sql.append(" and lower(").append(column).append(") like lower(?)");
            params.add("%" + value + "%");
        }
    }

    private void addBetweenWhere(StringBuilder sql, List<Object> params, String column, Object begin, Object end)
    {
        if (begin != null && StringUtils.isNotBlank(String.valueOf(begin)) && end != null && StringUtils.isNotBlank(String.valueOf(end)))
        {
            sql.append(" and ").append(column).append(" between ? and ?");
            params.add(begin);
            params.add(end);
        }
    }

    private void trimTrailingComma(StringBuilder sql)
    {
        int length = sql.length();
        if (length >= 2 && sql.substring(length - 2).equals(", "))
        {
            sql.setLength(length - 2);
        }
    }

    private void bind(PreparedStatement statement, List<Object> params) throws java.sql.SQLException
    {
        for (int i = 0; i < params.size(); i++)
        {
            Object value = params.get(i);
            if (value == null)
            {
                statement.setNull(i + 1, Types.NULL);
            }
            else
            {
                statement.setObject(i + 1, value);
            }
        }
    }

    private Object convertJdbcValue(Object value, Class<?> targetType)
    {
        if (value == null || targetType == null || targetType.isInstance(value))
        {
            return value;
        }
        if (targetType == Long.class || targetType == Long.TYPE)
        {
            return value instanceof Number ? ((Number) value).longValue() : Long.valueOf(String.valueOf(value));
        }
        if (targetType == Integer.class || targetType == Integer.TYPE)
        {
            return value instanceof Number ? ((Number) value).intValue() : Integer.valueOf(String.valueOf(value));
        }
        if (targetType == java.math.BigDecimal.class)
        {
            return value instanceof java.math.BigDecimal ? value : new java.math.BigDecimal(String.valueOf(value));
        }
        if (targetType == String.class)
        {
            return String.valueOf(value);
        }
        if (targetType == java.util.Date.class && value instanceof java.sql.Timestamp)
        {
            return new java.util.Date(((java.sql.Timestamp) value).getTime());
        }
        return value;
    }
